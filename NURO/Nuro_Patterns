// Template 1 — MAX LENGTH (return type = int length)
Map<Integer, Integer> map = new HashMap<>();
map.put(0, -1);                          // seed: sum=0 at index -1
int sum = 0, maxLen = 0;
for (int i = 0; i < n; i++) {
    sum += nums[i];                      // or transform: 0→-1 first
    if (map.containsKey(sum - k))
        maxLen = Math.max(maxLen, i - map.get(sum - k));
    if (!map.containsKey(sum))           // only first occurrence
        map.put(sum, i);
}


// Template 2 — COUNT subarrays (return type = int count)
Map<Integer, Integer> map = new HashMap<>();
map.put(0, 1);                           // seed: sum=0 occurred once
int sum = 0, count = 0;
for (int i = 0; i < n; i++) {
    sum += nums[i];
    count += map.getOrDefault(sum - k, 0);  // add ALL occurrences
    map.put(sum, map.getOrDefault(sum, 0) + 1);  // store frequency
}


// Template 3 — EXISTS / find pair (return type = boolean or indices)
Map<Integer, Integer> map = new HashMap<>();
for (int i = 0; i < n; i++) {
    int complement = target - nums[i];
    if (map.containsKey(complement))
        return new int[]{map.get(complement), i};
    map.put(nums[i], i);                 // store index
}

