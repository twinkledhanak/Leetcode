// 4. Angle from location to point (for visible points problem)
double angle(int fromX, int fromY, int toX, int toY) {
    return Math.toDegrees(Math.atan2(toY - fromY, toX - fromX));
}

// 5. Cross product — sign tells you turn direction
// positive = left turn, negative = right turn, zero = collinear
long cross(int ax, int ay, int bx, int by, int cx, int cy) {
    return (long)(bx-ax)*(cy-ay) - (long)(by-ay)*(cx-ax);
}

// 6. Area of triangle from 3 points (0 = collinear)
double area(int x1, int y1, int x2, int y2, int x3, int y3) {
    return Math.abs((x2-x1)*(y3-y1) - (x3-x1)*(y2-y1)) / 2.0;
}

// 7. Manhattan distance
int manhattan(int x1, int y1, int x2, int y2) {
    return Math.abs(x2-x1) + Math.abs(y2-y1);
}

// 8. Check if point (px,py) is inside rectangle
boolean inRect(int px, int py, int x1, int y1, int x2, int y2) {
    return px >= x1 && px <= x2 && py >= y1 && py <= y2;
}

