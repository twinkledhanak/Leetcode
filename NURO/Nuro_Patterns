// Regular binary search
// When I care for the insertion position and I know element also exists

int low=0, high=nums.length-1;
while(low <= high){
	int mid = low + (high-low)/2;
	if(nums[mid] == target)
		return mid;
	else if(nums[mid] > target)
		high = mid-1;
	else 
		low = mid+1;		
}

// if mid was returned => position of element
// low = insertion position of the element

------------------------------------------------------------------------------------------------
// Searching for boundary, the pivot point where array state transitions

int low=0, high=nums.length-1;
while(low <= high){
	int mid = low + (high-low)/2;
	if(nums[mid] > nums[n-1])
		low = mid+1; // low pivot is on right side
	else
		high = mid-1;	
}

// Nothing to do with mid
// low = point of transition, pivot, array state changed here
// nums[low] = minimum element of the array
// nums[n-1] OR nums[low-1] will have the max element

------------------------------------------------------------------------------------------------
// Search for Upper and lower bounds of a target
// When I care more on the insertion position for element that may not exist

int low=0, high=nums.length;
while(low < high){ // *** not <= ***
	int mid = lo + (hi - lo) / 2;
	if (arr[mid] ### target)  <= Upper bound ; < lower bound
            lo = mid + 1;
        else 
            hi = mid;  
	}
    return lo;

upperBound condition: arr[mid] <= target → lo = mid+1
Meaning: "mid is still within the valid zone, keep going right"
Result: lo lands on FIRST element STRICTLY GREATER than target

lowerBound condition: arr[mid] < target → lo = mid+1
Meaning: "mid is strictly less, keep going right"
Result: lo lands on FIRST element GREATER THAN OR EQUAL to target

Visually:
arr = [1, 2, 3, 3, 3, 5, 6], target=3

lowerBound: first position where arr[i] >= 3
            [1, 2, | 3, 3, 3, 5, 6]
                     ↑ index 2

upperBound: first position where arr[i] > 3
            [1, 2, 3, 3, 3, | 5, 6]
                               ↑ index 5

upperBound index - lowerBound index = array size of all 3's = 5 - 2 = 3 = count of 3s in array
    
