public int helper_Nodes(TreeNode root) {
    if (root == null) return 0;
    int left = helper_Nodes(root.left);
    int right = helper_Nodes(root.right);
    result = Math.max(result, left + right + 1);  // +1 counts bridge node
    return Math.max(left, right) + 1;             // height in nodes
}

