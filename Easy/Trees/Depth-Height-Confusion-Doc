public int helper_Edges(TreeNode root) {
    if (root == null) return 0;
    int left = helper_Edges(root.left);
    int right = helper_Edges(root.right);
    result = Math.max(result, left + right);  // NO +1, edges dont count bridge
    return Math.max(left, right) + 1;         // height still in nodes internally
}


